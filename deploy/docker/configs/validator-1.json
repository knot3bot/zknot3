{
  "network": {
    "bind_address": "0.0.0.0",
    "rpc_port": 9000,
    "p2p_enabled": true,
    "p2p_address": "0.0.0.0",
    "p2p_port": 8080,
    "local_peer_id": "validator-1",
    "bootstrap_peers": [
      "validator-2:8080",
      "validator-3:8080",
      "validator-4:8080"
    ],
    "max_connections": 256
  },
  "consensus": {
    "validator_enabled": true,
    "min_validator_stake": 1000000000,
    "min_validators": 4,
    "target_validators": 4,
    "max_validators": 4,
    "epoch_duration_secs": 60,
