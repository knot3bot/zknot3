    "enable_compaction": false
  },
  "vm": {
    "max_gas_budget": 10000000,
    "min_gas_price": 100,
    "max_bytecode_size": 65536
  },
  "authority": {
    "address": "zknot3-validator-1",
    "port": 8080,
    "stake": 1000000000000,
    "name": "Validator 1",
    "validator_index": 0
  },
  "logging": {
    "level": 2,
    "enable_file": false,
    "enable_stderr": true
  }
